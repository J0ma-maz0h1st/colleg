<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <handlers>
            <add name="httpplatformhandler" path="*" verb="*" modules="httpPlatformHandler" resourceType="Unspecified" />
        </handlers>
        <httpPlatform processPath="C:\Users\Администратор\project\back\env\Scripts\python.exe"
                      arguments="manage.py runserver %HTTP_PLATFORM_PORT%"
                      stdoutLogEnabled="true"
                      stdoutLogFile="C:\Users\Администратор\project\back\logs\python.log"
                      startupTimeLimit="60">
            <environmentVariables>
                <environmentVariable name="PYTHONPATH" value="C:\Users\Администратор\project\back" />
                <environmentVariable name="DJANGO_SETTINGS_MODULE" value="back.settings" />
            </environmentVariables>
        </httpPlatform>
    </system.webServer>
</configuration>